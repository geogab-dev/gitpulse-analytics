# .env

# logging settings
LOG_LEVEL=INFO
LOG_USE_COLORS=True

# minio credentials
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio_password
MINIO_ENDPOINT=http://localhost:9000

# minio buckets (medallion architecture)
MINIO_BUCKET_BRONZE=bronze
MINIO_BUCKET_SILVER=silver
MINIO_BUCKET_GOLD=gold

# postgres credentials for prefect server
POSTGRES_USER=prefect
POSTGRES_PASSWORD=prefect
POSTGRES_DB=prefect

# prefect server configuration
PREFECT_SERVER_API_HOST=0.0.0.0
PREFECT_SERVER_UI_API_URL=http://localhost:4200/api
PREFECT_API_DATABASE_CONNECTION_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# dashboard settings
DASHBOARD_DATA_SOURCE=minio
DASHBOARD_TITLE=GitPulse Analytics
DASHBOARD_CACHE_TTL=3600
DASHBOARD_STATIC_DATA_PATH=dashboard/data
