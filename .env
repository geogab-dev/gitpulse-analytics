# .env

# minio credentials
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio_password
MINIO_ENDPOINT=minio:9000

# postgres credentials for prefect server
POSTGRES_USER=prefect
POSTGRES_PASSWORD=prefect
POSTGRES_DB=prefect

# prefect server configuration
PREFECT_SERVER_API_HOST=0.0.0.0
PREFECT_SERVER_UI_API_URL=http://localhost:4200/api
PREFECT_API_DATABASE_CONNECTION_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
